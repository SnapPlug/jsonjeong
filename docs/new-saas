#!/usr/bin/env bash
# new-saas — Rails 8 + AI 코딩 최적화 프로젝트 부트스트랩
#
# 설치:
#   mkdir -p ~/bin
#   cp /Users/jason/jason/docs/new-saas ~/bin/new-saas
#   chmod +x ~/bin/new-saas
#   # ~/.zshrc 에 추가:  export PATH="$HOME/bin:$PATH"
#
# 사용:
#   new-saas <project-name>                       # 인터랙티브
#   new-saas <project-name> --type client --private --github-org acme
#
# 이 스크립트는 다음을 자동화한다:
#   1. rails new --css tailwind
#   2. CLAUDE.md 생성 (maker / client 템플릿 분기)
#   3. .gitignore 강화
#   4. (옵션) Rails 8 내장 인증 generator
#   5. Kamal / Cloudflare 배포 템플릿 파일 생성
#   6. 첫 git 커밋
#   7. (옵션) GitHub 레포 생성 + push

set -euo pipefail

VERSION="1.0.0"

# ---------- 색상 출력 ----------
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

info()    { printf "${BLUE}▸${RESET} %s\n" "$*"; }
success() { printf "${GREEN}✓${RESET} %s\n" "$*"; }
warn()    { printf "${YELLOW}⚠${RESET} %s\n" "$*"; }
error()   { printf "${RED}✗${RESET} %s\n" "$*" >&2; }
step()    { printf "\n${BOLD}${CYAN}━━ %s ━━${RESET}\n" "$*"; }

show_usage() {
  cat <<EOF
${BOLD}new-saas v$VERSION${RESET} — Rails 8 + AI 코딩 최적화 부트스트랩

${BOLD}Usage:${RESET}
  new-saas <project-name> [options]

${BOLD}Options:${RESET}
  --type maker|client       프로젝트 종류 (default: 프롬프트)
  --lang ko|en|bilingual    언어 정책 (default: 프롬프트)
  --no-auth                 Rails 인증 generator 건너뛰기
  --no-github               GitHub 레포 생성 건너뛰기
  --github-org <org>        GitHub 조직 (default: 프롬프트)
  --private                 Private 레포로 생성 (default: maker=public, client=private)
  --no-deploy-template      Kamal/Cloudflare 템플릿 파일 건너뛰기
  -h, --help                이 도움말

${BOLD}Examples:${RESET}
  new-saas snapdeck                                 # 인터랙티브
  new-saas snapteam --type maker --github-org SnapPlug
  new-saas acme-portal --type client --private --github-org acme-corp

${BOLD}프로젝트 이름 규칙:${RESET}
  - 소문자 + 숫자 + 하이픈만 (kebab-case)
  - 예: snapdeck, my-app, acme-portal-v2
EOF
}

# ---------- 인자 파싱 ----------
PROJECT_NAME=""
PROJECT_TYPE=""
LANG_POLICY=""
WITH_AUTH=1
WITH_GITHUB=1
WITH_DEPLOY_TEMPLATE=1
GITHUB_ORG=""
VISIBILITY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) show_usage; exit 0 ;;
    --type) PROJECT_TYPE="$2"; shift 2 ;;
    --lang) LANG_POLICY="$2"; shift 2 ;;
    --no-auth) WITH_AUTH=0; shift ;;
    --no-github) WITH_GITHUB=0; shift ;;
    --no-deploy-template) WITH_DEPLOY_TEMPLATE=0; shift ;;
    --github-org) GITHUB_ORG="$2"; shift 2 ;;
    --private) VISIBILITY="private"; shift ;;
    --public) VISIBILITY="public"; shift ;;
    -*) error "알 수 없는 옵션: $1"; show_usage; exit 1 ;;
    *) PROJECT_NAME="$1"; shift ;;
  esac
done

# ---------- 사전 검증 ----------
if [[ -z "$PROJECT_NAME" ]]; then
  error "프로젝트 이름이 필요합니다."
  show_usage
  exit 1
fi

if ! [[ "$PROJECT_NAME" =~ ^[a-z][a-z0-9-]*$ ]]; then
  error "프로젝트 이름은 소문자/숫자/하이픈만 허용. (kebab-case)"
  error "예: snapdeck, my-app, acme-portal"
  exit 1
fi

if [[ -d "$PROJECT_NAME" ]]; then
  error "디렉터리가 이미 존재합니다: $PROJECT_NAME"
  exit 1
fi

# 필수 도구 점검
for tool in ruby rails git; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    error "$tool 가 설치되지 않았습니다."
    case "$tool" in
      ruby)  echo "    설치: brew install mise && mise install ruby@3.3" ;;
      rails) echo "    설치: gem install rails -v '~> 8.1'" ;;
    esac
    exit 1
  fi
done

# Rails 버전 점검 (8.x 권장)
RAILS_VERSION=$(rails -v 2>/dev/null | awk '{print $2}' || echo "unknown")
if [[ ! "$RAILS_VERSION" =~ ^8\. ]]; then
  warn "Rails $RAILS_VERSION 감지. 이 스크립트는 Rails 8.x 가정. 계속하려면 Enter."
  read -r
fi

# ---------- 인터랙티브 프롬프트 ----------
prompt_select() {
  local question="$1"
  local default="$2"
  shift 2
  local options=("$@")

  echo -e "\n${BOLD}$question${RESET}"
  for i in "${!options[@]}"; do
    printf "  ${CYAN}%d)${RESET} %s\n" "$((i+1))" "${options[$i]}"
  done
  printf "선택 [default: %s]: " "$default"
  read -r choice
  if [[ -z "$choice" ]]; then
    echo "$default"
  else
    echo "${options[$((choice-1))]}"
  fi
}

prompt_text() {
  local question="$1"
  local default="$2"
  printf "\n${BOLD}%s${RESET}" "$question"
  if [[ -n "$default" ]]; then
    printf " [default: %s]" "$default"
  fi
  printf ": "
  read -r answer
  echo "${answer:-$default}"
}

prompt_yn() {
  local question="$1"
  local default="$2"  # Y or N
  local suffix
  if [[ "$default" == "Y" ]]; then suffix="[Y/n]"; else suffix="[y/N]"; fi
  printf "\n${BOLD}%s${RESET} %s: " "$question" "$suffix"
  read -r answer
  answer="${answer:-$default}"
  [[ "$answer" =~ ^[Yy]$ ]]
}

step "프로젝트 정보"

if [[ -z "$PROJECT_TYPE" ]]; then
  PROJECT_TYPE=$(prompt_select "프로젝트 종류는?" "maker" "maker" "client")
fi

if [[ -z "$LANG_POLICY" ]]; then
  if [[ "$PROJECT_TYPE" == "maker" ]]; then
    LANG_POLICY=$(prompt_select "언어 정책은?" "en" "en" "ko" "bilingual")
  else
    LANG_POLICY=$(prompt_select "언어 정책은? (클라이언트 요구사항)" "ko" "ko" "en" "bilingual")
  fi
fi

if [[ -z "$VISIBILITY" ]]; then
  if [[ "$PROJECT_TYPE" == "maker" ]]; then
    VISIBILITY="public"
  else
    VISIBILITY="private"
  fi
fi

PROJECT_PURPOSE=$(prompt_text "프로젝트 한 줄 설명 (영문 권장)" "")

if [[ $WITH_GITHUB -eq 1 ]] && [[ -z "$GITHUB_ORG" ]]; then
  DEFAULT_ORG=""
  if [[ "$PROJECT_TYPE" == "maker" ]]; then
    DEFAULT_ORG="SnapPlug"
  fi
  GITHUB_ORG=$(prompt_text "GitHub 조직/사용자명" "$DEFAULT_ORG")
fi

# ---------- 요약 + 확인 ----------
step "셋업 계획"
cat <<EOF
  프로젝트:        ${BOLD}$PROJECT_NAME${RESET}
  종류:            $PROJECT_TYPE
  언어 정책:       $LANG_POLICY
  설명:            ${PROJECT_PURPOSE:-<나중에 작성>}
  인증 generator:  $([ $WITH_AUTH -eq 1 ] && echo "예" || echo "아니오")
  배포 템플릿:     $([ $WITH_DEPLOY_TEMPLATE -eq 1 ] && echo "예" || echo "아니오")
  GitHub 레포:     $([ $WITH_GITHUB -eq 1 ] && echo "$GITHUB_ORG/$PROJECT_NAME ($VISIBILITY)" || echo "건너뜀")
EOF

if ! prompt_yn "이대로 진행할까요?" "Y"; then
  warn "취소했습니다."
  exit 0
fi

# ============================================================================
# 실제 셋업 시작
# ============================================================================

# ---------- Step 1: rails new ----------
step "1/7 Rails 8 앱 생성"
rails new "$PROJECT_NAME" --css tailwind
cd "$PROJECT_NAME"
success "Rails 앱 생성 완료"

# ---------- Step 2: .gitignore 강화 ----------
step "2/7 .gitignore 강화"
cat >> .gitignore <<'EOF'

# AI 코딩 도구 / 캐시
.gstack/
.claude/cache/
EOF
success ".gitignore 강화"

# ---------- Step 3: CLAUDE.md ----------
step "3/7 CLAUDE.md 생성"


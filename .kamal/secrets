# Secrets fed into Kamal at deploy time. Safe-for-git — no raw credentials here.
# Values resolve from ENV or commands at runtime.
#
# Required:
#   - RAILS_MASTER_KEY        — used to decrypt config/credentials.yml.enc
#   - KAMAL_REGISTRY_PASSWORD — GitHub PAT with write:packages scope (push image to ghcr.io)
#
# Generate a GitHub PAT here:
#   https://github.com/settings/tokens?scopes=write:packages
# Then export it in your shell (or stash via 1Password) before running kamal commands:
#   export KAMAL_REGISTRY_PASSWORD=ghp_xxx...
# Or put it once in ~/.zshrc.

RAILS_MASTER_KEY=$(cat config/master.key)
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

<section class="md:col-span-2 mt-10" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="text-xs font-bold uppercase tracking-wider text-muted">FAQ</h2>

  <div class="mt-3 border-t border-black/[0.06]">
    <% ApplicationHelper::FAQS.each do |item| %>
      <details class="group border-b border-black/[0.06] py-3">
        <summary class="flex items-start justify-between gap-3 cursor-pointer list-none [&::-webkit-details-marker]:hidden text-[15px] font-semibold text-ink">
          <span><%= item[:q] %></span>
          <span class="shrink-0 mt-0.5 text-muted transition-transform duration-200 group-open:rotate-45" aria-hidden="true">+</span>
        </summary>
        <p class="mt-2 text-[15px] leading-relaxed text-ink/80"><%= item[:a] %></p>
      </details>
    <% end %>
  </div>
</section>

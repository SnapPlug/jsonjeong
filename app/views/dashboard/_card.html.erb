<%
  status_emoji = { planning: "🟡", building: "🔵", shipped: "🟢" }[service.status] || "⚪"
  status_label = { planning: "준비 중", building: "개발 중", shipped: "출시" }[service.status] || service.status.to_s

  status_class = {
    planning: "bg-black/5 text-ink/70",
    building: "bg-brand/15 text-brand-dark",
    shipped:  "bg-brand-dark text-white"
  }[service.status] || "bg-black/5 text-ink/70"

  # Pre-revenue ($0): show the concept. Once it earns, flip to MRR like marclou.
  footer_meta = if service.mrr_usd.to_i.positive?
                  "$#{number_with_delimiter(service.mrr_usd.to_i)}/mo"
                else
                  service.concept
                end

  cta_url = if service.path.present?
              service.path
            else
              "#{newsletter_subdomain_url}?source=#{service.cta_source}"
            end
%>

<div class="bg-surface rounded-2xl p-6 flex flex-col gap-3">
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-center gap-2 min-w-0">
      <span class="text-xl shrink-0" aria-hidden="true"><%= service.emoji %></span>
      <h2 class="text-base font-bold text-ink truncate"><%= service.name %></h2>
    </div>
  </div>

  <% if service.demo_video.present? %>
    <video
      class="w-full rounded-xl border border-black/[0.06] bg-brand-dark aspect-video"
      autoplay muted loop playsinline
      poster="<%= service.demo_poster %>">
      <source src="<%= service.demo_video %>" type="video/mp4">
    </video>
  <% end %>

  <% if service.tagline.present? %>
    <p class="text-[15px] font-semibold text-ink leading-snug"><%= service.tagline %></p>
  <% end %>

  <% if service.subline.present? %>
    <p class="text-[15px] text-ink/90 leading-relaxed"><%= service.subline %></p>
  <% end %>

  <% if service.trust.present? %>
    <p class="text-sm font-semibold text-ink leading-snug"><%= service.trust %></p>
  <% end %>

  <div class="mt-auto pt-3 border-t border-black/[0.06] flex items-center justify-between gap-3 font-mono text-sm text-ink/70">
    <span class="inline-flex items-center gap-1.5">
      <span class="inline-flex items-center rounded-full <%= status_class %> text-xs font-semibold px-2 py-0.5">
        <%= status_emoji %> <%= status_label %>
      </span>
      <% if footer_meta.present? %>
        <span>·</span>
        <span><%= footer_meta %></span>
      <% end %>
    </span>
  </div>

  <%= link_to cta_url,
        class: "inline-flex items-center justify-center rounded-lg bg-brand text-brand-dark text-sm font-semibold px-4 py-2 hover:opacity-90 transition" do %>
    <%= service.cta_label || "소식 받기 →" %>
  <% end %>
</div>

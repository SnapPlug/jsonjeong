<div class="flex items-start gap-4 lg:block">
  <div class="w-20 h-20 lg:w-32 lg:h-32 rounded-full bg-brand overflow-hidden shrink-0">
    <picture>
      <source type="image/webp" srcset="<%= asset_path('profile.webp') %> 1x, <%= asset_path('profile@2x.webp') %> 2x">
      <source type="image/jpeg" srcset="<%= asset_path('profile@2x.jpeg') %>">
      <%= image_tag "profile@2x.jpeg",
            alt: "#{profile[:name]} profile picture",
            class: "w-full h-full object-cover",
            width: 400, height: 400,
            loading: "eager",
            fetchpriority: "high",
            decoding: "async" %>
    </picture>
  </div>

  <div class="flex-1 lg:mt-5">
    <h1 class="text-3xl lg:text-[36px] lg:leading-10 font-extrabold tracking-tight text-ink"><%= profile[:name] %></h1>

    <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-muted">
      <span class="inline-flex items-center gap-1">
        <span aria-hidden="true">📍</span><%= profile[:location] %>
      </span>
    </div>
  </div>
</div>

<p class="mt-4 text-[15px] leading-relaxed text-ink/90"><%= profile[:quote] %></p>


<p class="mt-4 font-semibold text-[15px]">
  <%= link_to profile[:newsletter_name], newsletter_subdomain_url,
        class: "text-brand underline underline-offset-4 decoration-2 hover:opacity-80" %>
  뉴스레터를 구독 중인 <%= profile[:newsletter_count] %>명과 함께하세요
</p>

<p class="mt-2 text-[15px] leading-relaxed text-ink/90"><%= profile[:newsletter_tagline] %></p>

<%= render "newsletter/subscribe_form",
      subscriber: Subscriber.new,
      source: "sidebar",
      cta: "현장 이야기 구독하기",
      placeholder: "컨설팅 현장 이야기를 받아보세요",
      url: newsletter_subscribe_path %>

<% if defined?(newsletter_issues) && newsletter_issues.present? %>
  <div class="mt-5">
    <p class="text-xs font-semibold tracking-wide text-muted uppercase">최근 글</p>
    <ul class="mt-2 space-y-2">
      <% newsletter_issues.each do |issue| %>
        <li class="text-[14px] leading-snug">
          <a href="<%= issue[:url] %>" target="_blank" rel="noopener"
             class="text-ink/90 hover:text-brand transition underline underline-offset-4 decoration-1 decoration-ink/20 hover:decoration-brand">
            <span class="text-muted mr-1">#<%= issue[:no] %></span><%= issue[:title] %>
          </a>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="mt-4 flex items-center gap-3 text-muted">
  <a href="<%= profile[:threads_url] %>" aria-label="Threads" target="_blank" rel="noopener me" class="hover:text-ink transition">
    <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
      <path d="M17.7 11.14a8.4 8.4 0 0 0-.31-.14c-.18-3.35-2.01-5.27-5.08-5.29h-.04c-1.84 0-3.37.78-4.31 2.21l1.69 1.16c.7-1.06 1.81-1.29 2.62-1.29h.03c1.01.01 1.77.3 2.27.87.36.42.6.99.72 1.72-.93-.16-1.93-.21-3-.15-3.02.17-4.95 1.93-4.82 4.38a3.79 3.79 0 0 0 1.46 2.81c.85.66 1.94.98 3.07.92 1.49-.08 2.66-.65 3.48-1.69.62-.79.99-1.79 1.18-3.06.74.45 1.29 1.04 1.6 1.75.51 1.21.55 3.21-1.07 4.82-1.42 1.42-3.13 2.04-5.74 2.06-2.88-.02-5.07-.95-6.48-2.75C3.65 17.07 2.96 14.83 2.95 12c.01-2.83.7-5.07 2.06-6.67C6.42 3.53 8.61 2.6 11.49 2.58c2.9.02 5.13.96 6.62 2.78.74.91 1.29 2.05 1.65 3.38l1.97-.52c-.43-1.63-1.11-3.03-2.04-4.16C17.78 1.78 14.97.59 11.5.58h-.01c-3.47.02-6.24 1.22-8.24 3.59C1.47 6.27.62 8.81.6 12v.01c.02 3.19.87 5.73 2.65 7.83 2 2.36 4.77 3.57 8.24 3.59h.02c3.08-.02 5.26-.83 7.05-2.62 2.34-2.34 2.27-5.28 1.5-7.08-.55-1.3-1.6-2.36-3.04-3.06zm-5.26 5.4c-1.25.07-2.55-.49-2.62-1.71-.05-.91.65-1.92 2.7-2.04l.55-.01c.59 0 1.15.06 1.65.17-.24 2.81-1.57 3.51-2.28 3.59z"/>
    </svg>
  </a>
  <a href="<%= profile[:x_url] %>" aria-label="X" target="_blank" rel="noopener me" class="hover:text-ink transition">
    <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.674l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
    </svg>
  </a>
</div>

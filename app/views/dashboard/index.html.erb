<div class="mx-auto px-5 py-10 lg:px-16 lg:py-16 lg:grid lg:grid-cols-[372px_1fr] lg:gap-x-32">
  <aside class="lg:sticky lg:top-16 lg:self-start">
    <%= render "profile", profile: @profile, bet: @bet %>
  </aside>

  <section class="mt-10 lg:mt-0 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4 auto-rows-min">
    <% @services.each do |service| %>
      <%= render "card", service: service %>
    <% end %>

    <p class="md:col-span-2 mt-2 text-sm text-muted">more teammates in the works — hiring one at a time.</p>

    <%= render "faq" %>
  </section>
</div>

<% content_for :head do %>
  <script type="application/ld+json"><%= raw faq_structured_data.to_json %></script>
<% end %>

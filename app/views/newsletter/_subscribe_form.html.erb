<%= form_with url: url, method: :post, local: true, class: "mt-6 flex flex-col gap-2" do |f| %>
  <%= hidden_field_tag :source, source %>

  <div class="flex">
    <%= email_field_tag :email, subscriber&.email,
          placeholder: (local_assigns[:placeholder] || "your@email.com"),
          required: true,
          class: "flex-1 min-w-0 rounded-l-lg border border-brand bg-white px-4 py-2.5 text-sm placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-brand focus:z-10" %>
    <%= submit_tag cta || "Subscribe",
          class: "rounded-r-lg bg-brand text-brand-dark font-semibold px-5 py-2.5 text-sm hover:opacity-90 transition border border-brand cursor-pointer" %>
  </div>

  <% if subscriber&.errors&.any? %>
    <p class="text-sm text-red-600 mt-1">
      <%= subscriber.errors.full_messages.first %>
    </p>
  <% end %>
<% end %>

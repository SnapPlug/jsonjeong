<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= page_description %>">
    <meta name="author" content="<%= ApplicationHelper::SITE_NAME %>">
    <meta name="robots" content="index, follow, max-image-preview:large">
    <meta name="theme-color" content="#181830">
    <link rel="canonical" href="<%= canonical_url %>">

    <meta property="og:type" content="website">
    <meta property="og:site_name" content="<%= ApplicationHelper::SITE_NAME %>">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:image" content="<%= og_image_url %>">
    <meta property="og:image:type" content="image/png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="<%= ApplicationHelper::SITE_TAGLINE %> — <%= ApplicationHelper::SITE_NAME %>">
    <meta property="og:locale" content="en_US">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@jasonjeongio">
    <meta name="twitter:creator" content="@jasonjeongio">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= og_image_url %>">
    <meta name="twitter:image:alt" content="<%= ApplicationHelper::SITE_TAGLINE %> — <%= ApplicationHelper::SITE_NAME %>">

    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= ApplicationHelper::SITE_NAME %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= render "shared/structured_data" %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png?v=3" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png?v=3">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="bg-page text-ink antialiased min-h-screen">
    <%= yield %>
  </body>
</html>
